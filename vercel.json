{
  "redirects": [
    { "source": "/admin", "destination": "/admin.html", "permanent": false },
    { "source": "/admin/login", "destination": "/admin.html", "permanent": false }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/server.js" },
    { "source": "/(.*)", "destination": "/public/$1" }
  ]
}
